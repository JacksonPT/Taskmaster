# Copy this file to .env and replace the placeholder with your Neon connection string.
# Never commit .env because it contains real credentials.

# Prisma uses this URL to connect to PostgreSQL.
# Neon connection strings usually start with postgresql:// and include sslmode=verify-full.
DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/DATABASE?sslmode=verify-full"

# Clerk uses the publishable key in browser-safe code and the secret key only on the server.
# Copy both values from the Clerk Dashboard API Keys page into your local .env.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY="pk_test_REPLACE_ME"
CLERK_SECRET_KEY="sk_test_REPLACE_ME"

# The Google provider reads this server-only key when it calls Gemini.
# Create a free-tier key in Google AI Studio; never prefix it with NEXT_PUBLIC_.
GOOGLE_GENERATIVE_AI_API_KEY="REPLACE_ME"
