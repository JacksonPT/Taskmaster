// Prisma schema defines the database shape in code.
// After editing this file, Prisma can generate TypeScript types and migrations.

generator client {
  // Prisma 7 generates a local TypeScript client at the output path below.
  // Our app imports that generated client from lib/prisma.ts.
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  // Neon hosts PostgreSQL, and Prisma reads the connection URL from prisma.config.ts.
  provider = "postgresql"
}

// Enums limit a field to a small list of allowed values.
// This keeps database values predictable and mirrors the UI priority badges.
enum TaskPriority {
  HIGH
  MEDIUM
  LOW
}

// These statuses map to the current UI states: Todo, In Progress, and Done.
enum TaskStatus {
  TODO
  IN_PROGRESS
  DONE
}

model Task {
  // cuid() creates unique string ids without needing the database to count upward.
  id String @id @default(cuid())

  title       String
  description String

  // Defaults let us create a task without manually providing every field.
  priority TaskPriority @default(MEDIUM)
  status   TaskStatus   @default(TODO)

  // dueDate is optional because users may create tasks without a deadline.
  dueDate DateTime?

  // AI suggestions will be generated later. For now this can stay empty.
  aiSuggestion String?

  // userId will store the Clerk user id later. It stays optional until auth is added.
  userId String?

  // Timestamps are useful for sorting, auditing, and dashboard stats later.
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
